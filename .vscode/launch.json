{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Spring Boot App",
            "request": "launch",
            "cwd": "${workspaceFolder}/API Rest-Springbot",
            "mainClass": "com.example.Application",
            "projectName": "api-rest-springbot",
            "preLaunchTask": "maven: clean",
            "args": "",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "type": "java",
            "name": "Attach to Process",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005,
            "preLaunchTask": "maven: clean"
        }
    ]
}
