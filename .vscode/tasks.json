{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "clean",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "package"
            ],
            "options": {
                "cwd": "${workspaceFolder}/API Rest-Springbot"
            },
            "presentation": {
                "reveal": "always"
            },
            "isBackground": false,
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "spring-boot run",
            "type": "shell",
            "command": "mvn",
            "args": [
                "spring-boot:run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/API Rest-Springbot"
            },
            "presentation": {
                "reveal": "always"
            },
            "isBackground": false
        },
        {
            "label": "run and debug",
            "type": "shell",
            "command": "mvn",
            "args": [
                "-Dspring-boot.run.jvmArguments=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=5005",
                "spring-boot:run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/API Rest-Springbot"
            },
            "presentation": {
                "reveal": "always"
            },
            "isBackground": true
        }
    ]
}
