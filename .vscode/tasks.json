{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "maven: clean",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "package"
            ],
            "problemMatcher": [
                "$javaTestRunner"
            ],
            "presentation": {
                "reveal": "always"
            },
            "isBackground": false,
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "maven: spring-boot:run",
            "type": "shell",
            "command": "mvn",
            "args": [
                "spring-boot:run"
            ],
            "problemMatcher": [
                "$javaTestRunner"
            ],
            "presentation": {
                "reveal": "always"
            },
            "isBackground": false
        }
    ]
}
