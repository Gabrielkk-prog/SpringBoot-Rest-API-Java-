{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "maven: clean",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "package"
            ],
            "options": {
                "cwd": "${workspaceFolder}/API Rest-Springbot"
            },
            "presentation": {
                "reveal": "always"
            },
            "isBackground": false,
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "maven: spring-boot:run",
            "type": "shell",
            "command": "mvn",
            "args": [
                "spring-boot:run"
            ],
            "options": {
                "cwd": "${workspaceFolder}/API Rest-Springbot"
            },
            "problemMatcher": [
                "$maven"
            ],
            "presentation": {
                "reveal": "always"
            },
            "isBackground": false
        }
    ]
}
